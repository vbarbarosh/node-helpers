{
    "author": "Vladimir Barbarosh <vladimir.barbarosh@gmail.com>",
    "license": "MIT",
    "name": "@vbarbarosh/node-helpers",
    "version": "3.76.0",
    "description": "A set of helpers for JavaScript/Node.js",
    "unpkg": "dist/browser.js",
    "jsdelivr": "dist/browser.js",
    "exports": {
        "./src/*.js": "./src/*.js",
        "./src/*": "./src/*.js",
        "./dist/*": "./dist/*",
        "./package.json": "./package.json"
    },
    "homepage": "https://vbarbarosh.github.io/node-helpers/",
    "bin": {
        "watchdog": "src/cli-apps/watchdog.js"
    },
    "files": [
        "dist",
        "src",
        "!src/**/*.test.js",
        "!src/**/*.d"
    ],
    "scripts": {
        "build": "rm -rf dist && webpack",
        "coverage": "c8 mocha 'src/**/*.test.js'",
        "lint": "eslint src webpack.config.js eslint.config.js",
        "test": "mocha 'src/**/*.test.js'"
    },
    "keywords": [
        "js",
        "node",
        "helpers"
    ],
    "engines": {
        "node": ">=22"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vbarbarosh/node-helpers.git"
    },
    "bugs": {
        "url": "https://github.com/vbarbarosh/node-helpers/issues"
    },
    "dependencies": {
        "@paralleldrive/cuid2": "^3.3.0",
        "@vbarbarosh/type-helpers": "^0.2.0",
        "axios": "^1.7.9",
        "bluebird": "^3.7.2",
        "csv-parse": "^7.0.1",
        "form-data": "^4.0.1",
        "htmlparser2": "^12.0.0",
        "json-stable-stringify": "^1.2.1",
        "json-stringify-safe": "^5.0.1",
        "mime-types": "^3.0.2",
        "sanitize-filename": "^1.6.3",
        "split": "^1.0.1"
    },
    "optionalDependencies": {
        "redis": "^4.6.0",
        "ssh2": "^1.16.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vbarbarosh/tree": "^0.5.0",
        "c8": "^11.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "eslint": "^10.7.0",
        "express": "^5.2.1",
        "globals": "^17.7.0",
        "mocha": "^11.0.1",
        "redis-v1": "npm:redis@1",
        "redis-v2": "npm:redis@2",
        "redis-v3": "npm:redis@3",
        "redis-v4": "npm:redis@4",
        "redis-v5": "npm:redis@^5.12.1",
        "redis-v6": "npm:redis@^6.1.0",
        "throttle": "^1.0.3",
        "tree-kill": "^1.2.2",
        "webpack": "^5.98.0",
        "webpack-cli": "^7.2.1"
    }
}
